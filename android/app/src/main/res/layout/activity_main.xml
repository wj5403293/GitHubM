<?xml version="1.0" encoding="utf-8"?>
<!--
  LinearLayout（竖向）：
    - WebView：填充剩余空间，显示 Web 应用内容
    - BottomNavigationView：固定在底部，高度 56dp，映射核心导航功能
  splashOverlay 叠加于整个布局顶层，启动时遮盖初始化闪烁。
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 主体：WebView + 底部导航栏垂直排列 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!--
          底部导航容器：BottomNavigationView 固定 56dp，不接收系统导航条 inset，
          避免 updatePadding(bottom) 压缩内部可用高度导致图标与文字重叠。
          系统导航条（手势条/按键条）高度由 navBarSpacer 独立承接。
        -->
        <LinearLayout
            android:id="@+id/bottomNavContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bottom_nav_background"
            android:elevation="8dp">

            <com.google.android.material.bottomnavigation.BottomNavigationView
                android:id="@+id/bottomNav"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:color/transparent"
                app:menu="@menu/bottom_nav_menu"
                app:itemIconTint="@color/bottom_nav_colors"
                app:itemTextColor="@color/bottom_nav_colors"
                app:itemTextAppearanceActive="@style/BottomNavTextActive"
                app:itemTextAppearanceInactive="@style/BottomNavTextInactive"
                app:labelVisibilityMode="labeled"
                app:elevation="0dp" />

            <!-- 系统导航条占位符：由 WindowInsets 动态设置高度，不影响 BottomNavView 布局 -->
            <View
                android:id="@+id/navBarSpacer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:background="@color/bottom_nav_background" />

        </LinearLayout>

    </LinearLayout>

    <!-- 启动遮罩：全屏启动画面，WebView 就绪后淡出 -->
    <include
        android:id="@+id/splashOverlay"
        layout="@layout/splash_screen"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>

